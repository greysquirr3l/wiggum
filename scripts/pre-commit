#!/usr/bin/env bash
# Pre-commit hook for wiggum
# Runs cargo fmt and cargo audit before allowing commits

set -e

echo "Running pre-commit checks..."

# Run cargo fmt and stage any changes
echo "→ Running cargo fmt..."
cargo fmt --all

# Stage any formatting changes
git diff --name-only | grep '\.rs$' | while read -r file; do
    if [ -f "$file" ]; then
        git add "$file"
    fi
done

# Run cargo audit for security vulnerabilities
echo "→ Running cargo audit..."
if ! command -v cargo-audit &> /dev/null; then
    echo "⚠️  cargo-audit not installed, skipping security audit"
    echo "   Install with: cargo install cargo-audit"
else
    cargo audit
fi

echo "✓ Pre-commit checks passed"
